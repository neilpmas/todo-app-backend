<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">
    <!-- Used only inside the Docker build stage to resolve GitHub Packages dependencies
         (dev.neilmason:connectrpc-spring-boot-starter, a stopgap until it's on Maven
         Central; see pom.xml's repositories comment). GITHUB_PACKAGES_TOKEN is supplied
         at build time via a BuildKit build secret (see Dockerfile), never baked into an
         image layer. -->
    <servers>
        <server>
            <id>github-connectrpc-spring</id>
            <username>neilpmas</username>
            <password>${env.GITHUB_PACKAGES_TOKEN}</password>
        </server>
        <server>
            <id>github-connectrpc-spring-boot</id>
            <username>neilpmas</username>
            <password>${env.GITHUB_PACKAGES_TOKEN}</password>
        </server>
    </servers>
</settings>
